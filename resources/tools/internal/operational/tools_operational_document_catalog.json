    {
      "id": "merge_pdfs",
      "tool_id": "merge_pdfs",
      "display_name_i18n": "tools.merge_pdfs.display_name",
      "short_description_i18n": "tools.merge_pdfs.short_description",
      "description_i18n": "tools.merge_pdfs.long_description",
      "long_description_i18n": "tools.merge_pdfs.long_description",
      "tool_kind": "operational",
      "surface": "operational",
      "origin": "internal",
      "category": "document_processing",
      "catalog_ref": "resources/tools/internal/operational/tools_operational_document_catalog.json",
      "status": "declared_only",
      "enabled": true,
      "execution_enabled": false,
      "execution_implemented": false,
      "requires_confirmation": true,
      "requires_owner_ref": true,
      "risk_level": "medium",
      "allowed_contexts": [
        "chat",
        "DocumentHolder"
      ],
      "forbidden_contexts": [
        "project_root_outputs",
        "llm_direct_execution"
      ],
      "input_schema": {
        "arguments": [
          {
            "name": "pdf_files",
            "type": "file_ref_list",
            "required": true,
            "multiplicity": "many",
            "ordered": true,
            "min_items": 2,
            "allowed_extensions": [
              ".pdf"
            ],
            "source_policy": "governed_reference_or_explicit_user_selection",
            "validation_rules": [
              "must_be_pdf",
              "min_items_2"
            ],
            "description_i18n": "tools.merge_pdfs.input.pdf_files"
          },
          {
            "name": "output_filename",
            "type": "text",
            "required": false,
            "default": "merged.pdf",
            "validation_rules": [
              "relative_filename_only",
              "pdf_extension"
            ],
            "description_i18n": "tools.merge_pdfs.input.output_filename"
          }
        ]
      },
      "output_schema": {
        "outputs": [
          {
            "name": "merged_pdf",
            "type": "file",
            "required": true,
            "persistence": "persisted",
            "target_policy": "owner_scoped",
            "allowed_extensions": [
              ".pdf"
            ],
            "description_i18n": "tools.merge_pdfs.output.merged_pdf"
          }
        ]
      },
      "persistence_policy": {
        "persistence": "persisted",
        "requires_owner_ref": true,
        "forbid_project_root_outputs": true,
        "requires_tool_run_manifest": true
