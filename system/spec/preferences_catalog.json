      "label": {
        "es": "Proveedor LLM en modo cloud",
        "en": "Cloud LLM provider"
      },
      "help": {
        "es": "Selecciona el proveedor a usar cuando el modo cloud esté habilitado.",
        "en": "Select the provider to use when cloud mode is enabled."
      },
      "exposed": true,
      "ui_control": "select",
      "group": "llm",
      "section": "providers",
      "order": 20,
      "tags": [
        "llm",
        "cloud"
      ],
      "visible_if": {
        "all": [
          {
            "key": "llm.cloud_allowed",
            "equals": true
          }
        ]
      },
      "enabled_if": {
        "all": [
          {
            "key": "llm.cloud_allowed",
            "equals": true
          }
        ]
      }
    },
