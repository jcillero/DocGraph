      "owner_policy": {
        "owner_ref_required": true,
        "allowed_owner_kinds": [
          "chat",
          "DocumentHolder"
        ]
      },
      "trace_requirements": [
        "tool_id",
        "tool_kind",
        "run_id",
        "owner_ref",
        "inputs",
        "configuration",
        "outputs",
        "status",
        "created_at",
        "trace",
        "errors",
        "warnings"
      ],
      "visible_text": {
        "input_labels_i18n": {
          "pdf_files": "tools.merge_pdfs.input.pdf_files",
          "output_filename": "tools.merge_pdfs.input.output_filename"
        },
        "output_labels_i18n": {
          "merged_pdf": "tools.merge_pdfs.output.merged_pdf"
        },
        "confirmation_message_i18n": "tools.merge_pdfs.confirmation",
        "success_message_i18n": "tools.merge_pdfs.success",
        "error_message_i18n": "tools.merge_pdfs.error"
