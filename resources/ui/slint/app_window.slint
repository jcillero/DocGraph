export component AppWindow inherits Window {
    in property <string> title_text;
    in property <string> subtitle_text;

    width: 960px;
    height: 640px;
    title: title_text;

    VerticalLayout {
        alignment: center;
        spacing: 12px;

        Text {
            text: title_text;
            horizontal-alignment: center;
        }

        Text {
            text: subtitle_text;
            horizontal-alignment: center;
        }
    }
}
