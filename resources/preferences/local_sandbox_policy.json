{
  "version": 1,
  "sandbox_definition": "authorized_empty_external_local_folder",
  "must_be_outside_app": true,
  "forbidden_inside": [
    "crates",
    "resources",
    "runtime",
    "user",
    "output",
    "assets",
    "dev",
    "docs",
    "scripts"
  ],
  "future_mutation_inside_sandbox_allowed": true,
  "mutation_outside_sandbox_allowed": false,
  "llm_direct_execution_allowed": false,
  "mutable_actions_enabled_now": false
}
