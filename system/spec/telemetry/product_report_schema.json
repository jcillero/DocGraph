{
  "schema_version": "1.0.0",
  "title": "Product Telemetry Report Schema",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at_utc",
    "summary",
    "zones",
    "alerts"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "generated_at_utc": {
      "type": "string",
      "description": "UTC timestamp in ISO 8601 format."
    },
    "summary": {
      "type": "object",
      "required": [
        "total_files",
        "total_size_bytes",
        "document_count",
        "outputs_count"
      ],
      "properties": {
        "total_files": {
          "type": "integer",
          "minimum": 0
        },
        "total_size_bytes": {
          "type": "integer",
          "minimum": 0
        },
        "document_count": {
          "type": "integer",
          "minimum": 0
        },
        "outputs_count": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "zones": {
      "type": "object",
      "required": [
        "runs",
        "outputs",
        "registry"
      ],
      "properties": {
        "runs": {
          "$ref": "#/definitions/zone_metrics"
        },
        "outputs": {
          "$ref": "#/definitions/zone_metrics"
        },
        "registry": {
          "$ref": "#/definitions/zone_metrics"
        }
      }
    },
    "by_extension": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/extension_metrics"
      }
    },
    "largest_files": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/file_entry"
      }
    },
    "largest_folders": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/folder_entry"
      }
    },
    "alerts": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/alert_entry"
      }
    }
  },
  "definitions": {
    "zone_metrics": {
      "type": "object",
      "required": [
        "file_count",
        "size_bytes"
      ],
      "properties": {
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "extension_metrics": {
      "type": "object",
      "required": [
        "extension",
        "file_count",
        "size_bytes"
      ],
      "properties": {
        "extension": {
          "type": "string"
        },
        "file_count": {
          "type": "integer",
          "minimum": 0
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "file_entry": {
      "type": "object",
      "required": [
        "relative_path",
        "size_bytes"
      ],
      "properties": {
        "relative_path": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "folder_entry": {
      "type": "object",
      "required": [
        "relative_path",
        "size_bytes"
      ],
      "properties": {
        "relative_path": {
          "type": "string"
        },
        "size_bytes": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "alert_entry": {
      "type": "object",
      "required": [
        "code",
        "message",
        "severity"
      ],
      "properties": {
        "code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "severity": {
          "type": "string",
          "enum": ["info", "warning", "critical"]
        }
      }
    }
  }
}