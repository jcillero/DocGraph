# ------------------------------------------------------------
# Python cache
# ------------------------------------------------------------

__pycache__/
*.pyc
*.pyo
*.pyd
*.py[cod]

# ------------------------------------------------------------
# Virtual environments (if ever used)
# ------------------------------------------------------------

.venv/
venv/
env/

# ------------------------------------------------------------
# OS generated files
# ------------------------------------------------------------

.DS_Store
Thumbs.db
desktop.ini

# ------------------------------------------------------------
# Temporary files
# ------------------------------------------------------------

*.log
*.tmp
*.bak
*.swp

# ------------------------------------------------------------
# User execution traces (generated at runtime)
# ------------------------------------------------------------

user/runs/

# ------------------------------------------------------------
# Generated outputs
# ------------------------------------------------------------

user/output/

# ------------------------------------------------------------
# Local input datasets (optional)
# ------------------------------------------------------------

user/input/*

# Keep folder structure
!user/input/.keep

# ------------------------------------------------------------
# Development artifacts
# ------------------------------------------------------------

dev/ai/outputs/
dev/reports/
dev/tmp/

# ------------------------------------------------------------
# Local runtime binaries (optional portable bundles)
# ------------------------------------------------------------

system/bin/runtimes/**/tmp/
system/bin/runtimes/**/cache/

# ------------------------------------------------------------
# Local configuration overrides
# ------------------------------------------------------------

*.local.json
*.secrets.json