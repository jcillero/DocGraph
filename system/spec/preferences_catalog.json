{
  "catalog_id": "preferences_catalog",
  "schema_version": "2.0.0",
  "updated_at": "2026-03-09T00:00:00Z",
  "languages_allowed": [
    "es",
    "en"
  ],
  "merge_policy": {
    "base_catalog_required": true,
    "plugin_catalogs_allowed": true,
    "plugin_catalog_paths": [
      "system/plugins/*/preferences_catalog.json",
      "user/plugins/*/preferences_catalog.json",
      "dev/plugins/*/preferences_catalog.json"
    ],
    "conflict_resolution": "last_override_wins",
    "unknown_fields_policy": "ignore"
  },
  "notes": {
    "es": "Catálogo ULTRA de preferencias con soporte para grupos, orden, condiciones, dependencias y catálogos aportados por plugins. Solo se admiten español e inglés.",
    "en": "ULTRA preferences catalog with support for groups, ordering, conditions, dependencies, and plugin-contributed catalogs. Only Spanish and English are supported."
  },
