{
  "schema_version": "logging.work_units_catalog.v1",

  "rules": {
    "primary_required": true,
    "count_must_be_non_negative_integer": true,
    "unit_must_be_from_catalog": true,
    "secondary_allowed": true,
    "secondary_may_repeat_unit": false,
    "primary_count_zero_allowed": true,
    "extensible": true,
    "renames_not_allowed_without_major_version": true
  },

  "units": [
    "pages",
    "images",
    "tables",
    "lines",
    "chars",
    "bytes",
    "files",
    "documents",
    "artifacts",

    "chunks",
    "tokens",
    "vectors",
    "queries",
    "results",

    "triples",
    "entities",
    "edges",

    "rows",
    "columns",

    "iterations",
    "steps",
    "actions"
  ],

  "recommended_primary_by_stage": {
    "ingest": "files",
    "validation": "files",
    "process": "files",

    "ocr": "pages",
    "clean": "chars",

    "embed": "chunks",
    "vector_search": "queries",

    "kg": "triples",
    "causal": "rows",

    "math": "iterations",
    "export": "files",

    "workflow": "steps",
    "ui": "actions",

    "run": "files"
  },

  "recommended_secondary_by_stage": {
    "ingest": ["bytes", "documents"],
    "ocr": ["images"],
    "clean": ["lines"],
    "embed": ["tokens", "vectors"],
    "vector_search": ["results"],
    "kg": ["entities", "edges"],
    "causal": ["columns"],
    "export": ["documents", "artifacts"]
  },

  "constraints": {
    "secondary_units_must_be_unique": true
  },

  "examples": {
    "ocr_example": {
      "primary": { "unit": "pages", "count": 42 },
      "secondary": [
        { "unit": "images", "count": 120 }
      ]
    },
    "embed_example": {
      "primary": { "unit": "chunks", "count": 350 },
      "secondary": [
        { "unit": "tokens", "count": 125000 },
        { "unit": "vectors", "count": 350 }
      ]
    },
    "kg_example": {
      "primary": { "unit": "triples", "count": 18000 },
      "secondary": [
        { "unit": "entities", "count": 2200 },
        { "unit": "edges", "count": 5400 }
      ]
    },
    "causal_example": {
      "primary": { "unit": "rows", "count": 125000 },
      "secondary": [
        { "unit": "columns", "count": 37 }
      ]
    },
    "export_example": {
      "primary": { "unit": "files", "count": 3 },
      "secondary": [
        { "unit": "documents", "count": 3 },
        { "unit": "artifacts", "count": 5 }
      ]
    }
  }
}