{
  "version": 1,
  "template_id": "basic_markdown_report_v1",
  "status": "proposal_declared_only",
  "execution_enabled": false,
  "document_kind": "report",
  "artifact_format": "markdown",
  "default_conformity_mode": "guided",
  "layers": {
    "structure": {
      "sections": [
        {
          "section_id": "summary",
          "heading": "Summary",
          "required": true,
          "order": 1
        },
        {
          "section_id": "context",
          "heading": "Context",
          "required": true,
          "order": 2
        },
        {
          "section_id": "findings",
          "heading": "Findings",
          "required": true,
          "order": 3
        },
        {
          "section_id": "next_steps",
          "heading": "Next Steps",
          "required": false,
          "order": 4
        }
      ]
    },
    "style": {
      "font_family": "proposal",
      "heading_style": "numbered_optional",
      "citation_style": "unset"
    },
    "export": {
      "profiles": [
        "markdown_to_latex_clean_v1",
        "markdown_to_pdf_clean_v1",
        "markdown_to_docx_clean_v1"
      ]
    },
    "references": {
      "reference_style_id": "apa_7_example",
      "allowed_style_kinds": [
        "standard",
        "corporate",
        "custom_project"
      ],
      "allowed_reference_kinds": [
        "project_document",
        "bibtex_entry",
        "doi",
        "isbn",
        "url",
        "manual_metadata",
        "cross_reference"
      ]
    },
    "bibliography": {
      "enabled": true,
      "sources": [],
      "block": "bibliography"
    },
    "metadata": {
      "title": null,
      "author": null,
      "language": "en"
    },
    "guidance": {
      "sections": [
        {
          "section_id": "summary",
          "purpose": "State the document outcome briefly.",
          "recommended_tone": "focused",
          "recommended_length": "short",
          "expected_content": [
            "decision",
            "status",
            "main conclusion"
          ],
          "forbidden_content": [
            "unverified claims"
          ],
          "quality_checklist": [
            "Can a reader understand the outcome in under one minute?"
          ],
          "internal_observations": [
            "Do not export this note unless explicitly allowed by the export profile."
          ],
          "export_notes": [
            "Keep summary before detailed sections."
          ]
        }
      ]
    }
  },
  "allowed_override_types": [
    "structural_overrides",
    "style_overrides",
    "export_overrides",
    "reference_overrides",
    "metadata_overrides",
    "guidance_overrides"
  ],
  "drift_dimensions": [
    "style_drift",
    "metadata_drift",
    "export_drift",
    "structure_drift",
    "semantic_drift"
  ],
  "forbidden": [
    "execute_export",
    "call_llm",
    "mutate_existing_documents",
    "run_external_tools",
    "use_ui_state_as_export_source"
  ]
}
