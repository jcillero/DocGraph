{
  "schema_version": "1.0.0",
  "document": {
    "id": "DATA_MODEL_MIN",
    "status": "stable",
    "authority": "system/spec",
    "description": "Contrato mínimo del modelo de datos para persistencia (SQLite / JSONL)."
  },
  "conventions": {
    "id_type": "uuid4",
    "timestamp_format": "ISO-8601",
    "soft_delete": false,
    "naming": "snake_case"
  },
  "tables": {
    "documents": {
      "description": "Entidad base documental registrada en el sistema.",
      "primary_key": "document_id",
      "fields": {
        "document_id": "string (uuid)",
        "title": "string",
        "file_path": "string (relative to user/input or managed storage)",
        "file_type": "string (pdf, docx, md, etc)",
        "size_bytes": "integer",
        "created_at": "datetime",
        "registered_at": "datetime",
        "ocr_required": "boolean",
        "ocr_completed": "boolean",
        "hash_sha256": "string",
        "status": "string (active | archived)"
      }
    },

    "collections": {
      "description": "Agrupación lógica de documentos.",
      "primary_key": "collection_id",
      "fields": {
        "collection_id": "string (uuid)",
        "name": "string",
        "description": "string",
        "created_at": "datetime"
      }
    },

    "collection_document": {
      "description": "Relación many-to-many entre documentos y colecciones.",
      "primary_key": "composite (collection_id, document_id)",
      "fields": {
        "collection_id": "string (uuid)",
        "document_id": "string (uuid)",
        "linked_at": "datetime"
      },
      "constraints": [
        "FK collection_id → collections.collection_id",
        "FK document_id → documents.document_id"
      ]
    },

    "runs": {
      "description": "Registro técnico de ejecuciones de tools.",
      "primary_key": "run_id",
      "fields": {
        "run_id": "string (uuid)",
        "tool_id": "string",
        "status": "string (ok | fail | warn)",
        "started_at": "datetime",
        "finished_at": "datetime",
        "duration_ms": "integer",
        "preset_used": "string (nullable)",
        "error_message": "string (nullable)"
      }
    },

    "artifacts": {
      "description": "Artefactos generados por tools.",
      "primary_key": "artifact_id",
      "fields": {
        "artifact_id": "string (uuid)",
        "run_id": "string (uuid)",
        "tool_id": "string",
        "artifact_type": "string (pdf | json | md | txt | other)",
        "relative_path": "string (relative to user/output/)",
        "created_at": "datetime"
      },
      "constraints": [
        "FK run_id → runs.run_id"
      ]
    }
  },
  "directory_mapping": {
    "runs_directory": "user/runs/",
    "artifacts_directory": "user/output/"
  },
  "invariants": [
    "Every artifact must be linked to exactly one run.",
    "Every run must reference a declared tool_id from runtime_registry.",
    "No artifact may be written outside user/output/.",
    "No run metadata may be written outside user/runs/."
  ]
}