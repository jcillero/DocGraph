{
  "schema": "ui_theme_spec",
  "version": "1.1.0",
  "description": {
    "es": "Definición de temas visuales para la interfaz de DocGraph.",
    "en": "Visual theme definitions for the DocGraph interface."
  },
  "themes": {
    "light": {
      "theme_id": "docgraph_light_v1",
      "colors": {
        "bg_app": "#F4F6F8",
        "bg_panel": "#E9EDF2",
        "bg_log": "#E3E7EC",
        "text_primary": "#1C1C1C",
        "text_secondary": "#4B5563",
        "brand_primary": "#2F5D8C",
        "state_ok": "#3A7D44",
        "state_warn": "#B58900",
        "state_error": "#A93226",

        "bg": "#F2F2F2",
        "panel": "#FFFFFF",
        "fg": "#1A1A1A",
        "muted": "#5F6368",
        "border": "#CFCFCF",
        "accent": "#2F6FED",

        "input_bg": "#FFFFFF",
        "input_fg": "#111111",

        "button_bg": "#EAEAEA",
        "button_fg": "#111111",

        "tab_bg": "#E8E8E8",
        "tab_active_bg": "#FFFFFF",
        "tab_fg": "#111111"
      },
      "typography": {
        "font_family_base": "system_default",
        "size_h1": 16,
        "size_h2": 14,
        "size_body": 12,
        "size_small": 10
      }
    },

    "dark": {
      "theme_id": "docgraph_dark_v1",
      "colors": {
        "bg_app": "#1E1E1E",
        "bg_panel": "#252526",
        "bg_log": "#2A2D2E",
        "text_primary": "#F3F3F3",
        "text_secondary": "#B8B8B8",
        "brand_primary": "#4C8DFF",
        "state_ok": "#4FA36A",
        "state_warn": "#D4A72C",
        "state_error": "#D96B5F",

        "bg": "#1E1E1E",
        "panel": "#252526",
        "fg": "#F3F3F3",
        "muted": "#B8B8B8",
        "border": "#3A3A3A",
        "accent": "#4C8DFF",

        "input_bg": "#2D2D30",
        "input_fg": "#F3F3F3",

        "button_bg": "#2D2D30",
        "button_fg": "#F3F3F3",

        "tab_bg": "#2A2A2A",
        "tab_active_bg": "#252526",
        "tab_fg": "#F3F3F3"
      },
      "typography": {
        "font_family_base": "system_default",
        "size_h1": 16,
        "size_h2": 14,
        "size_body": 12,
        "size_small": 10
      }
    }
  }
}